# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Maps Platform Key for interactive maps
GOOGLE_MAPS_PLATFORM_KEY="YOUR_API_KEY"

# Configuración de Correo Real (SMTP / Gmail)
# Define estas variables en el panel de Configuración (Settings) / Secrets de AI Studio
# para habilitar el envío de correos electrónicos reales a tus clientes.
SMTP_USER="edwinraulrosasalbines@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_SENDER_NAME="Maison Rosas"

# Configuración de Resend API (Solución sin contraseñas de aplicación)
# Coloca tu API key en los Secrets de AI Studio:
RESEND_API_KEY="re_xxxx"
# Tu correo verificado en Resend (por defecto se usará edwinraulrosasalbines@gmail.com o el que configures)
RESEND_SENDER_EMAIL="edwinraulrosasalbines@gmail.com"


