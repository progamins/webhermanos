# ══════════════════════════════════════════════════════════════════
# 🐳 DOCKER (cópia este archivo a .env y ajusta los valores)
# ══════════════════════════════════════════════════════════════════
# IMPORTANTE para Docker: DB_HOST debe ser "db" (nombre del servicio
# definido en docker-compose.yml), NO "localhost".
#
# Puerto MySQL expuesto en tu máquina host (por defecto 3306).
DB_PORT_PUBLISHED=3306
# Puerto donde se sirve la app en tu máquina host (por defecto 3000).
APP_PORT_PUBLISHED=3000
# Contraseña root del contenedor MySQL (la usa compose para inicializarlo).
MYSQL_ROOT_PASSWORD=cambia_esta_root_password

# ============================================
# 🗄️ BASE DE DATOS (MySQL)
# ============================================
# Configuración de la base de datos MySQL.
# - En Docker: DB_HOST=db  (contenedor del compose)
# - Sin Docker (local con XAMPP): DB_HOST=localhost
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=cambia_esta_root_password
DB_NAME=maison_rosas

# ============================================
# 🌐 APP URL
# ============================================
# Sin Docker: APP_URL=http://localhost:3000
# Con Docker (puerto por defecto): APP_URL=http://localhost:3000
APP_URL="http://localhost:3000"

# Google Maps Platform Key for interactive maps
GOOGLE_MAPS_PLATFORM_KEY="YOUR_API_KEY"

# ============================================
# 📧 CONFIGURACIÓN DE CORREO (GRATUITA)
# ============================================
# El formulario de contacto y las notificaciones de pedidos usan
# Nodemailer + Gmail SMTP, que es 100% gratuito (hasta 500 emails/día).
#
# 📋 Cómo configurarlo (solo 3 pasos):
# 1. Activa la verificación en 2 pasos en tu cuenta de Google:
#    https://myaccount.google.com/security
# 2. Genera una Contraseña de Aplicación:
#    https://myaccount.google.com/apppasswords
#    Selecciona "Correo" y "Windows Computer"
# 3. Copia la contraseña de 16 dígitos y pégala abajo:
SMTP_USER="tu_correo@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_SENDER_NAME="Tu Negocio"

# Alternativa: Resend API (gratuito 100 emails/día)
# Si prefieres no usar SMTP, puedes usar Resend:
# 1. Regístrate gratis en https://resend.com
# 2. Verifica tu correo (onboarding@resend.dev o tu dominio)
# 3. Copia tu API key aquí:
RESEND_API_KEY="re_xxxx"
RESEND_SENDER_EMAIL="tu_correo@resend.dev"

# ============================================
# 📊 GOOGLE ANALYTICS 4 (Gratuito)
# ============================================
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ============================================
# 🔐 CONTRASEÑAS INICIALES DE ROLES (seed)
# ============================================
# Solo se usan la primera vez al poblar la BD (npm run db:seed).
# OBLIGATORIO: la app no arrancará sin estos valores.
# Cámbialas por seguridad y recuerda rotarlas desde el panel admin.
ADMIN_DEFAULT_PASSWORD="cambia_esta_admin_password"
ANALYST_DEFAULT_PASSWORD="cambia_esta_analyst_password"
STOCK_MANAGER_DEFAULT_PASSWORD="cambia_esta_stock_password"

# ============================================
# 🛡️ RUTA SECRETA DEL PANEL ADMIN
# ============================================
# Cadena aleatoria larga que se concatena a la URL del panel admin.
# OBLIGATORIO. Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET_PATH="cambia_esta_ruta_secreta_genera_una_aleatoria_larga"

# ============================================
# 🌐 CONTROL DE ACCESO ADMIN (opcional)
# ============================================
# Lista separada por comas de IPs/MACs permitidas para el panel admin.
# Vacío = sin restricción por IP/MAC (solo credenciales). Solo para entornos
# donde quieras blindar el acceso (ej. IP pública de oficina).
# ALLOWED_ADMIN_IPS="127.0.0.1,::1,192.168.15.0/24"
# ALLOWED_MAC_ADDRESSES="MAC_ADDRESS_PLACEHOLDER"

