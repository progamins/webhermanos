{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Maison Rosas Cake Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "flavors": { "type": "array" },
        "decorations": { "type": "array" },
        "preparationTime": { "type": "string" },
        "active": { "type": "boolean" },
        "stock": { "type": "boolean" },
        "tags": { "type": "array" }
      },
      "required": ["id", "name", "description", "basePrice", "category"]
    },
    "Review": {
      "title": "Review",
      "description": "User Review of a Cake",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "role": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "cakeModel": { "type": "string" },
        "date": { "type": "string" },
        "approved": { "type": "boolean" },
        "response": { "type": "string" }
      },
      "required": ["id", "author", "rating", "comment", "cakeModel", "date"]
    },
    "Order": {
      "title": "Order",
      "description": "Maison Rosas Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "cakeId": { "type": "string" },
        "cakeName": { "type": "string" },
        "flavor": { "type": "string" },
        "decoration": { "type": "string" },
        "message": { "type": "string" },
        "deliveryDate": { "type": "string" },
        "deliveryTime": { "type": "string" },
        "deliveryType": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["id", "customerName", "customerPhone", "cakeId", "cakeName", "deliveryDate", "totalPrice", "status", "date"]
    },
    "GalleryItem": {
      "title": "GalleryItem",
      "description": "Maison Rosas Gallery Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "imageUrl", "title", "category", "date"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Application general configuration",
      "type": "object",
      "properties": {
        "whatsappNumber": { "type": "string" },
        "facebookUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "openingHours": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "maintenanceMode": { "type": "boolean" }
      }
    },
    "AdminSession": {
      "title": "AdminSession",
      "description": "Sesión activa del administrador",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "expiresAt": { "type": "string" }
      },
      "required": ["token", "expiresAt"]
    },
    "CakeStock": {
      "title": "CakeStock",
      "description": "Stock físico de pasteles listos para entrega inmediata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "productId": { "type": "string" },
        "flavor": { "type": "string" },
        "size": { "type": "string" },
        "decoration": { "type": "string" },
        "quantity": { "type": "number" },
        "createdAt": { "type": "string" },
        "notes": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "productId", "flavor", "size", "decoration", "quantity", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Colección de productos de pasteles"
    },
    "reviews": {
      "schema": "Review",
      "description": "Colección de opiniones de clientes"
    },
    "orders": {
      "schema": "Order",
      "description": "Colección de pedidos personalizados"
    },
    "gallery": {
      "schema": "GalleryItem",
      "description": "Colección de fotos de pasteles reales entregados"
    },
    "config": {
      "schema": "AppConfig",
      "description": "Documentos de configuración global"
    },
    "admin_sessions": {
      "schema": "AdminSession",
      "description": "Colección de sesiones activas del administrador"
    },
    "cake_stock": {
      "schema": "CakeStock",
      "description": "Colección de stock físico de pasteles listos"
    }
  }
}
