# =============================================================================
# HostGator Production Configuration — Maison Rosas
# =============================================================================

# Enable rewrite engine
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS (activar en producción con SSL instalado)
  RewriteCond %{HTTPS} off
  RewriteCond %{REQUEST_URI} !^/\.well-known/
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # SPA: Don't rewrite files or directories that physically exist
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA: Rewrite everything else to index.html for React Router
  RewriteRule ^ index.html [L]

  # Security: Block access to sensitive files
  RewriteRule ^\.env - [F,L]
  RewriteRule ^\.env\. - [F,L]
  RewriteRule ^server\.ts$ - [F,L]
  RewriteRule ^vite\.config\.ts$ - [F,L]
  RewriteRule ^node_modules/ - [F,L]
  RewriteRule ^\.git - [F,L]
</IfModule>

# =============================================================================
# Security Headers
# =============================================================================
<IfModule mod_headers.c>
  # Protect against clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # Prevent MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Enable XSS filter (legacy, but safe)
  Header always set X-XSS-Protection "1; mode=block"

  # Referrer policy
  Header always set Referrer-Policy "no-referrer-when-downgrade"

  # HSTS (HTTP Strict Transport Security) - fuerza HTTPS en el navegador por 1 año
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Permissions policy (restrict APIs)
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # Content Security Policy (CSP) - protección contra XSS
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.firebaseio.com https://*.googleapis.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://www.google-analytics.com wss:; frame-src 'self' https://*.firebaseapp.com; media-src 'self' https:; object-src 'none'; base-uri 'self'; form-action 'self'"
</IfModule>

# =============================================================================
# Caching — Static Assets (1 year for hashed files, 1 week for others)
# =============================================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # Default: 1 week
  ExpiresDefault "access plus 1 week"

  # HTML: 1 hour (SPA updates frequently)
  ExpiresByType text/html "access plus 1 hour"

  # CSS, JS: 1 year (vite hashes filenames)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Images: 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts: 1 year
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# =============================================================================
# Compression (GZip / Brotli)
# =============================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# =============================================================================
# MIME Types
# =============================================================================
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType font/woff2 .woff2
</IfModule>

# =============================================================================
# Directory listing protection
# =============================================================================
Options -Indexes

# =============================================================================
# Custom error pages
# =============================================================================
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html
