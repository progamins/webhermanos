#!/bin/bash
# ═══════════════════════════════════════════════════════════════════
#  duck.sh — Actualizador DDNS para DuckDNS (EJEMPLO)
#  Copia este archivo como duck.sh y reemplaza TOKEN con tu token
# ═══════════════════════════════════════════════════════════════════

set -euo pipefail

# ─── Configuración ───────────────────────────────────────────────
DOMAIN="TU_DOMINIO"          # Ej: maisonrosas
TOKEN="TU_TOKEN_DUCKDNS"     # Reemplázalo con tu token real
LOG_FILE="/var/log/duckdns.log"
IP_SOURCE="https://api.ipify.org"
DUCK_URL="https://www.duckdns.org/update?domains=${DOMAIN}&token=${TOKEN}&ip="
# ──────────────────────────────────────────────────────────────────

TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
CURRENT_IP=$(curl -s --connect-timeout 10 "$IP_SOURCE" 2>/dev/null)

if [ -z "$CURRENT_IP" ]; then
    echo "[$TIMESTAMP] ❌ ERROR: No se pudo obtener IP pública" >> "$LOG_FILE"
    exit 1
fi

RESPONSE=$(curl -s --connect-timeout 10 "${DUCK_URL}${CURRENT_IP}" 2>/dev/null)

if [ "$RESPONSE" = "OK" ]; then
    echo "[$TIMESTAMP] ✅ Actualizado: $DOMAIN.duckdns.org → $CURRENT_IP" >> "$LOG_FILE"
else
    echo "[$TIMESTAMP] ⚠️  Respuesta inesperada: '$RESPONSE'" >> "$LOG_FILE"
fi
