rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── PUBLIC READ COLLECTIONS ───
    // Anyone can read products, reviews, gallery, config (for catalog, testimonials, etc.)
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reviews/{doc} {
      allow read: if true;
      allow create: if true;  // Customers can submit reviews
      allow update, delete: if request.auth != null;  // Admin operations via authenticated server
    }

    match /gallery/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── ORDERS ───
    // Customers can create orders via server API or check tracking via read
    // All update/delete operations require authentication (admin via server)
    match /orders/{doc} {
      allow read: if true;       // Public read for tracking code lookup
      allow create: if true;     // Customers can place orders (via /api/orders)
      allow update, delete: if request.auth != null;  // Admin only via authenticated server
    }

    // ─── ADMIN-ONLY COLLECTIONS ───
    // These require Firebase Auth (server uses anonymous auth)
    // Admin sessions, stock, emails, and OTPs are never accessed from client-side directly
    match /admin_sessions/{doc} {
      allow read, write: if request.auth != null;
    }

    match /cake_stock/{doc} {
      allow read, write: if request.auth != null;
    }

    match /simulated_emails/{doc} {
      allow read, write: if request.auth != null;
    }

    match /otps/{doc} {
      allow read, write: if request.auth != null;
    }

    // ─── DENY EVERYTHING ELSE ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
